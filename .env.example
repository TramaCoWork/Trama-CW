# PostgreSQL
POSTGRES_USER=trama
POSTGRES_PASSWORD=trama_secret
POSTGRES_DB=trama_cowork
POSTGRES_PORT=5432

# App
DATABASE_URL="postgresql://trama:trama_secret@localhost:5432/trama_cowork"
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development

# Uploads
UPLOAD_PATH=./uploads  # Default: ./uploads (en Docker usar /app/uploads)

# Mail (optional - defaults to ConsoleTransport if not set)
# MAIL_PROVIDER=smtp|gmail  (leave empty for console output in dev)
# MAIL_FROM=noreply@trama.com

# SMTP (required if MAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user@example.com
# SMTP_PASS=secret

# Gmail (required if MAIL_PROVIDER=gmail)
# GMAIL_USER=user@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
