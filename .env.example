# PostgreSQL
POSTGRES_USER=trama
POSTGRES_PASSWORD=trama_secret
POSTGRES_DB=trama_cowork
POSTGRES_PORT=5432

# App
DATABASE_URL="postgresql://trama:trama_secret@localhost:5432/trama_cowork"
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4321

# Uploads
UPLOAD_PATH=./uploads  # Default: ./uploads (en Docker usar /app/uploads)
# COMMUNITY_UPLOAD_PATH: las imágenes de community se guardan automáticamente en $UPLOAD_PATH/community/
COMMUNITY_MAX_IMAGES_PER_ENTITY=10

# Mail (optional - defaults to ConsoleTransport if not set)
MAIL_PROVIDER=smtp
MAIL_FROM=Trama CoWork <no-responder@tramacowork.com>

# SMTP (required if MAIL_PROVIDER=smtp)
SMTP_HOST=a0100748.ferozo.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-responder@tramacowork.com
SMTP_PASS=your_smtp_password_here

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx  # Public key para inicializar Checkout Bricks en el front
MERCADOPAGO_WEBHOOK_SECRET=xxxxxxxx      # Clave secreta para validar la firma (x-signature) de los webhooks
SUBSCRIPTION_NOTIFICATION_URL=https://api.tudominio.com/subscriptions/webhook

# Contact form
SUPPORT_EMAIL=soporte@tramacowork.com
TURNSTILE_SECRET_KEY=0x4AAAAAAA...  # Cloudflare Turnstile secret key (optional in dev)

# Background Jobs (configuración de cron schedules)
# JSON donde cada clave es un job name y el valor es una expresión cron.
# Si un job no está en el JSON, no se registra.
# Si la variable no se setea, se usan los defaults de cada job.
# Ej: CRON_SCHEDULE={"expiredTrials":"0 0 * * *","subscriptionRenewals":"0 0 * * *"}
CRON_SCHEDULE={"expiredTrials":"0 0 * * *","expiredCancelledSubs":"0 0 * * *","subscriptionRenewals":"0 0 * * *","applyDiscounts":"0 1 * * *","restoreDiscounts":"0 2 * * *"}
