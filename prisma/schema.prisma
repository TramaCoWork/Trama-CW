generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  client
  professional
  admin
}

enum ProfileStatus {
  incomplete
  onboarding
  pending_review
  active
  suspended
  rejected
  waiting_payment
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum ContactType {
  whatsapp
  email
}

enum WorkModality {
  presencial
  online
  ambas
}

enum WorkType {
  independiente
  freelance
  emprendedor
  otro
}

enum EducationLevel {
  secundario
  terciario
  universitario
  posgrado
  maestria
  doctorado
  certificacion
}

enum DocumentType {
  dni
  cv
  title
  certificate
}

enum ValidationStatus {
  pending_review
  manual_approved
  manual_rejected
  ai_approved
  ai_rejected
}

enum ValidationType {
  manual
  ai
}

enum DocumentVerificationStatus {
  pending
  approved
  rejected
}

enum UsageFrequency {
  daily
  three_four_weekly
  occasional
}

enum FrequencyType {
  days
  months
  years
}

enum SubscriptionStatus {
  pending
  authorized
  active
  paused
  cancelled
  expired
}

enum SubscriptionPaymentStatus {
  sub_pending
  sub_approved
  sub_rejected
  sub_refunded
}

enum PostStatus {
  published
  paused
}

enum CommunityImageEntityType {
  POST
  COMMENT
  MESSAGE
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String    @map("password_hash")
  role             UserRole  @default(client)
  emailVerified    Boolean   @default(false) @map("email_verified")
  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  profile    ProfessionalProfile?
  payments   Payment[]
  subscriptions Subscription[]
  posts      CommunityPost[]
  comments   CommunityComment[]
  communityImages CommunityImage[]
  jobApplies JobApplication[]
  reviews    ProfileValidation[]
   verifiedDocuments Document[] @relation("DocumentVerifier")
  createdDiscounts Discount[] @relation("DiscountCreator")
  sentMessages PrivateMessage[] @relation("MessageSender")
  receivedMessages PrivateMessage[] @relation("MessageReceiver")

  @@map("users")
}

model ProfessionalProfile {
  id            String        @id @default(uuid())
  userId        String        @unique @map("user_id")
  name          String
  bio           String?       @db.Text
  photo         String?
  services      String[]
  priceMin      Decimal?      @map("price_min") @db.Decimal(10, 2)
  priceMax      Decimal?      @map("price_max") @db.Decimal(10, 2)
  city          String?
  whatsapp      String?
  emailContact  String?       @map("email_contact")
  isActive      Boolean       @default(false) @map("is_active")
  profileStatus ProfileStatus @default(incomplete) @map("profile_status")
  completionPct Int           @default(0) @map("completion_pct")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // ─── Rubro principal (nivel 1, obligatorio al registrarse) ──────────────
  rubroId       Int?          @map("rubro_id")

  // ─── Geolocalización ───────────────────────────────────────────────────────
  countryId     Int?          @map("country_id")
  provinceId    Int?          @map("province_id")

  // ─── Datos personales (seccion 1) ──────────────────────────────────────────
  dni              String?
  birthDate        DateTime?     @map("birth_date")
  linkedin         String?
  pricePerHour     Decimal?      @map("price_per_hour") @db.Decimal(10, 2)
  workModality     WorkModality? @map("work_modality")

  // ─── Perfil profesional (seccion 2) ────────────────────────────────────────
  currentOccupation String?      @map("current_occupation")
  workType          WorkType?    @map("work_type")
  workTypeOther     String?      @map("work_type_other")
  industry          String?
  yearsExperience   Int?         @map("years_experience")

  // ─── Intereses y uso (secciones 6-7) ───────────────────────────────────────
  interestsInTrama  String[]     @map("interests_in_trama")
  usageFrequency    UsageFrequency? @map("usage_frequency")
  spaceTypes        String[]     @map("space_types")

  // ─── Pregunta filtro (seccion 8) ───────────────────────────────────────────
  tramaMotivation   String?      @map("trama_motivation") @db.VarChar(300)

  // ─── Consentimiento (seccion 9) ────────────────────────────────────────────
  termsAccepted       Boolean   @default(false) @map("terms_accepted")
  dataConsentAccepted Boolean   @default(false) @map("data_consent_accepted")

  // ─── Control de onboarding ─────────────────────────────────────────────────
  isFirstTime    Boolean   @default(true)  @map("is_first_time")
  currentStep    Int       @default(1)     @map("current_step")
  submittedAt    DateTime? @map("submitted_at")

  // ─── Trial / Suscripcion ────────────────────────────────────────────────────
  trialEndDate   DateTime? @map("trial_end_date")

  // ─── Documentos de identidad (archivos fisicos, sin tabla Document) ────────
  identityFrontUrl  String?  @map("identity_front_url")
  identityBackUrl   String?  @map("identity_back_url")

  // ─── Relaciones ────────────────────────────────────────────────────────────
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  rubro               ProfessionCategory?   @relation("ProfessionalRubro", fields: [rubroId], references: [id])
  country             Country?              @relation(fields: [countryId], references: [id])
  province            Province?             @relation(fields: [provinceId], references: [id])
  contacts            ContactLog[]
  educations          Education[]
  certifications      Certification[]
  documents           Document[]
   validations         ProfileValidation[]
  professionCategories ProfessionCategory[]
  discounts           Discount[]

  @@index([city], name: "professionals_city")
  @@index([isActive], name: "professionals_active")
  @@index([city, workModality, isActive], name: "professionals_search")
  @@index([rubroId, isActive], name: "professionals_rubro")
  @@map("professional_profiles")
}

model Payment {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("ARS")
  status          PaymentStatus @default(pending)
  paymentProvider String        @map("payment_provider")
  externalId      String?       @map("external_id")
  metadata        Json?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("payments")
}

model Job {
  id             String   @id @default(uuid())
  title          String
  description    String   @db.Text
  createdByAdmin Boolean  @default(true) @map("created_by_admin")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  applications JobApplication[]

  @@map("jobs")
}

model JobApplication {
  id          String   @id @default(uuid())
  jobId       String   @map("job_id")
  userId      String   @map("user_id")
  coverLetter String?  @map("cover_letter") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
  @@map("job_applications")
}

model CommunityPost {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  channelSlug String     @default("general") @map("channel_slug")
  status      PostStatus @default(published)
  content     String     @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user     User               @relation(fields: [userId], references: [id])
  comments CommunityComment[]

  @@index([channelSlug])
  @@map("community_posts")
}

model CommunityComment {
  id        String    @id @default(uuid())
  postId    String    @map("post_id")
  userId    String    @map("user_id")
  content   String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id])

  @@map("community_comments")
}

model CommunityImage {
  id         String                    @id @default(uuid())
  userId     String                    @map("user_id")
  entityType CommunityImageEntityType?
  entityId   String?                   @map("entity_id")
  filename   String
  url        String
  mimeType   String                    @map("mime_type")
  size       Int
  uploadedAt DateTime                  @default(now()) @map("uploaded_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "community_images_user")
  @@index([entityType, entityId], name: "community_images_entity")
  @@map("community_images")
}

model ContactLog {
  id             String      @id @default(uuid())
  professionalId String      @map("professional_id")
  contactType    ContactType @map("contact_type")
  estimated      Boolean     @default(false)
  createdAt      DateTime    @default(now()) @map("created_at")

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id])

  @@map("contact_logs")
}

// ─── Formacion academica (seccion 3) ──────────────────────────────────────────

model Education {
  id              String         @id @default(uuid())
  professionalId  String         @map("professional_id")
  level           EducationLevel
  title           String
  institution     String
  year            Int?
  professionId    Int?           @map("profession_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  profession   ProfessionCategory? @relation("EducationProfession", fields: [professionId], references: [id])
  documents    Document[]

  @@map("educations")
}

// ─── Certificaciones (seccion 4) ──────────────────────────────────────────────

model Certification {
  id              String   @id @default(uuid())
  professionalId  String   @map("professional_id")
  name            String
  institution     String
  year            Int?
  professionId    Int?     @map("profession_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  profession   ProfessionCategory? @relation("CertificationProfession", fields: [professionId], references: [id])
  documents    Document[]

  @@map("certifications")
}

// ─── Documentos (archivos subidos) ────────────────────────────────────────────

model Document {
  id              String       @id @default(uuid())
  professionalId  String       @map("professional_id")
  type            DocumentType
  fileUrl         String       @map("file_url")
  originalName    String       @map("original_name")
  mimeType        String       @map("mime_type")
  sizeBytes       Int          @map("size_bytes")
  uploadedAt      DateTime     @default(now()) @map("uploaded_at")

  // Relacion opcional con Education o Certification
  educationId     String?      @map("education_id")
  certificationId String?      @map("certification_id")

  // Relacion opcional con profesion (para validar que el documento corresponde a una profesion)
  professionId    Int?         @map("profession_id")

  // Verificacion del documento
  verificationStatus  DocumentVerificationStatus @default(pending) @map("verification_status")
  verifiedBy          String?          @map("verified_by")
  verifiedAt          DateTime?        @map("verified_at")
  verificationNotes   String?          @map("verification_notes") @db.Text
  verificationType    ValidationType?  @map("verification_type")

  professional  ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  education     Education?          @relation(fields: [educationId], references: [id], onDelete: SetNull)
  certification Certification?      @relation(fields: [certificationId], references: [id], onDelete: SetNull)
  profession    ProfessionCategory? @relation("DocumentProfession", fields: [professionId], references: [id])
  verifier      User?               @relation("DocumentVerifier", fields: [verifiedBy], references: [id])

  @@map("documents")
}

// ─── Validacion de perfil ─────────────────────────────────────────────────────

model ProfileValidation {
  id                String           @id @default(uuid())
  professionalId    String           @map("professional_id")
  status            ValidationStatus
  validationType    ValidationType   @map("validation_type")
  reviewedBy        String?          @map("reviewed_by")
  reviewNotes       String?          @map("review_notes") @db.Text
  documentsReviewed String[]         @map("documents_reviewed")
  confidenceScore   Float?           @map("confidence_score")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  reviewer     User?               @relation(fields: [reviewedBy], references: [id])

  @@map("profile_validations")
}

// ─── Taxonomia de profesiones (jerarquica: rubro → sub-rubro → profesion) ────

model ProfessionCategory {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  parentId  Int?     @map("parent_id")
  level     Int      @default(1)
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   ProfessionCategory?  @relation("ProfessionHierarchy", fields: [parentId], references: [id])
  children ProfessionCategory[] @relation("ProfessionHierarchy")

  // Profesionales que tienen este nodo como rubro (solo nivel 1)
  professionalsAsRubro ProfessionalProfile[] @relation("ProfessionalRubro")

  // Profesionales que seleccionaron esta profesion (solo nivel 3)
  professionals ProfessionalProfile[]

  // Documentos, educaciones, certificaciones vinculadas a esta profesion
  documents      Document[]      @relation("DocumentProfession")
  educations     Education[]     @relation("EducationProfession")
  certifications Certification[] @relation("CertificationProfession")

  @@map("profession_categories")
}

// ─── Planes de suscripción ────────────────────────────────────────────────────

model SubscriptionPlan {
  id            String        @id @default(uuid())
  name          String
  description   String?       @db.Text
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("ARS")
  frequency     Int           @default(1)
  frequencyType FrequencyType @default(months) @map("frequency_type")
  trialDays     Int           @default(0) @map("trial_days")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

// ─── Suscripciones ────────────────────────────────────────────────────────────

model Subscription {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  planId          String             @map("plan_id")
  externalId      String?            @unique @map("external_id")
  status          SubscriptionStatus @default(pending)
  startDate       DateTime?          @map("start_date")
  trialEndDate    DateTime?          @map("trial_end_date")
  endDate         DateTime?          @map("end_date")
  nextPaymentDate DateTime?          @map("next_payment_date")
  mpPayerEmail    String?            @map("mp_payer_email")
  initPoint       String?            @map("init_point") @db.Text
  cancellationReason String?         @map("cancellation_reason") @db.Text
  paymentStrategy    String?         @map("payment_strategy")
  metadata        Json?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id])
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  payments SubscriptionPayment[]

  @@index([userId, status], name: "subscriptions_user_status")
  @@map("subscriptions")
}

// ─── Pagos de suscripción ─────────────────────────────────────────────────────

model SubscriptionPayment {
  id             String                    @id @default(uuid())
  subscriptionId String                    @map("subscription_id")
  externalId     String?                   @unique @map("external_id")
  amount         Decimal                   @db.Decimal(10, 2)
  status         SubscriptionPaymentStatus @default(sub_pending)
  attemptNumber  Int                       @default(1) @map("attempt_number")
  paidAt         DateTime?                 @map("paid_at")
  failedAt       DateTime?                 @map("failed_at")
  failureReason  String?                   @map("failure_reason")

  // Datos del medio de pago (extraídos de MP)
  paymentMethod      String?   @map("payment_method")        // credit_card, debit_card, account_money, etc.
  paymentMethodId    String?   @map("payment_method_id")     // visa, master, amex, etc.
  cardLastFourDigits String?   @map("card_last_four_digits")
  installments       Int?
  statusDetail       String?   @map("status_detail")         // accredited, cc_rejected_other_reason, etc.

  // Raw completo de MP para auditoría
  metadata       Json?
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("subscription_payments")
}

// ─── Geolocalización ──────────────────────────────────────────────────────────

model Country {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  code      String     @unique               // ISO 3166-1 alpha-2 (ej: "AR")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  provinces    Province[]
  professionals ProfessionalProfile[]

  @@map("countries")
}

model Province {
  id        Int      @id @default(autoincrement())
  name      String
  countryId Int      @map("country_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  country       Country               @relation(fields: [countryId], references: [id])
  professionals ProfessionalProfile[]

  @@unique([countryId, name])
  @@map("provinces")
}

// ─── Descuentos ───────────────────────────────────────────────────────────────

model Discount {
  id              String    @id @default(uuid())
  professionalId  String    @map("professional_id")

  // Uno de los dos debe tener valor. Se aplica percentage si tiene valor, sino fixedAmount
  percentage      Decimal?  @db.Decimal(5, 2)
  fixedAmount     Decimal?  @map("fixed_amount") @db.Decimal(10, 2)

  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")

  // Control de aplicación
  applied         Boolean   @default(false)
  appliedAt       DateTime? @map("applied_at")
  restored        Boolean   @default(false)
  restoredAt      DateTime? @map("restored_at")

  // Auditoría
  createdBy       String    @map("created_by")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")

  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  creator         User                @relation("DiscountCreator", fields: [createdBy], references: [id])

  @@index([professionalId, startDate, endDate], name: "discounts_professional_dates")
  @@map("discounts")
}

model PrivateMessage {
  id                String   @id @default(uuid())
  senderId          String   @map("sender_id")
  receiverId        String   @map("receiver_id")
  content           String   @db.Text
  sentAt            DateTime @default(now()) @map("sent_at")
  readAt            DateTime? @map("read_at")
  deletedBySender   Boolean  @default(false) @map("deleted_by_sender")
  deletedByReceiver Boolean  @default(false) @map("deleted_by_receiver")

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, sentAt], name: "private_messages_sender_receiver_sent_at")
  @@map("private_messages")
}
